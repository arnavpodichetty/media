# Copy this file to .env and fill in your own values. Never commit the real .env.

# Neon (or any Postgres with pgvector support) connection string.
# Get one free at https://neon.tech -> create project -> Connection Details.
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# https://www.themoviedb.org/settings/api (free, instant)
TMDB_API_KEY=

# --- LLM backend for taste profiles + recommendation reranking ---
# Any OpenAI-compatible chat-completions endpoint. base_url must include /v1.
#
# Local llama.cpp / Ollama (no cost, needs a GPU/CPU to run the model):
#   LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
#   LOCAL_LLM_MODEL=qwen3.5-4b          # cosmetic for llama-server
#   LOCAL_LLM_API_KEY=                  # leave blank
#
# Hosted provider (works when deployed, no local GPU needed):
#   Groq (free, fast):  base_url=https://api.groq.com/openai/v1
#                       model=llama-3.3-70b-versatile
#   DeepSeek (cheap):   base_url=https://api.deepseek.com/v1
#                       model=deepseek-chat
#   ...set LOCAL_LLM_API_KEY to the provider's key.
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=local-model
LOCAL_LLM_API_KEY=

# Minimum seconds between LLM calls during seeding. 0 for a local server;
# raise it (e.g. 2) if a hosted free tier rate-limits you.
# LLM_MIN_INTERVAL_SECONDS=0

HARDCOVER_API_TOKEN=
RAWG_API_KEY=
LASTFM_API_KEY=
